                [    ...    ]
                [     0     ] => CS(rsp) == rsp + 136
                [   crip    ] => RIP(rsp) == rsp + 128             # same
                [     0     ] => ORIG_RAX(rsp) == rsp + 120
                [    rdi    ] => RDI(rsp) == rsp + 112
                [    rsi    ] => RSI(rsp == rsp + 104
                [    rdx    ] => RDX(rsp) == rsp + 96
                [    rcx    ] => RCX(rsp) == rsp + 88
