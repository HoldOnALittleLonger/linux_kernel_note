                    /* ftrace_ops is in the process of being added. */
                    FTRACE_OPS_FL_ADDING                    = BIT(8),

                    /* ftrace_ops is in the process of being removed. */
                    FTRACE_OPS_FL_REMOVING                  = BIT(9),

                    /* ftrace_ops is in the process of changing its
