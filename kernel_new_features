                       *        sirq   => 1 => 3 - 1 => 2 => 1 << 2 => 00100
                       *        hirq   => 2 => 3 - 2 => 1 => 1 << 1 => 00010
                       *        nirq   => 3 => 3 - 3 => 0 => 1 << 0 => 00001
                       *
