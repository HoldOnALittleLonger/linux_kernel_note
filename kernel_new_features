           * we do not know if it is rax? rbx? ...
           * but we can use at most ten registers in a
           * eBPF program,operates them like the assembly language.
           */
          enum {
                  BPF_REG_0 = 0,
                  BPF_REG_1,
                  BPF_REG_2,
                  BPF_REG_3,
                  BPF_REG_4,
                  BPF_REG_5,
                  BPF_REG_6,
