        eBPF instruction structure :
          <linux/bpf.h>
            /**
             * bpf_insn - structure to describes one instruction of the
             *            eBPF program defined by user
             * @code:     operation code
             * @dst_reg:  destination operand register
             * @src_reg:  source operand register
             * @off:      signed offset for specific instruction
             * @imm:      signed immediate constant - such $0x20
             * # we can construct eBPF program by setup several bpf_insn
             *   structures,and use the corresponding command to load them.
             */
            struct bpf_insn {
                    __u8 code;
                    __u8 dst_reg:4;
                    __u8 src_reg:4;
                    __s16 off;
                    __s32 imm;
            };
            ! bytecodes for eBPF opcodes are defined in <linux/bpf.h> and
              <linux/bpf_common.h>.
              an eBPF opcode usually is combined by a part of
                      instruction classes /* instruction class */
                      operand length      /* operand length */
                      mode                /* op mode,r2r, r2m, ... */
                      operation code      /* opcode */
                      src operand r/m     /* in reg or in mem */

            ! we can only call to the pre-defined functions provided by eBPF,
              is not allowed call to kernel function directly.

