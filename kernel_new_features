ftrace :
        ftrace relies the profile feature mcount(),which is a function included
        in the profiling library.when compile program with "-pg" gcc option,
        an assembly instruction "call mcount" is inserted to the head of the
        function.
        mcount() routine recording in an in-memory call graph table both its
        parent routine(child, function called mcount()),and its parent's parent
        (the routine called mcount()'s parent).
        this is typically done by examining the stack frame to find both the
        address of the child,and the return address in the original parent.
        because this is machine-dependent,thus mcount() will call to the
        function __mcount_internal()(a normal C function),which is architecture
        dependent,pass the function @frompc and @selfpc.
        @frompc is the program counter where this child function is called(next ins),
        and @selfpc the address of this child routine(with mcount() size adjustment,
        remove size of the mcount() call that is embedded in the function).
        __mcount_internal() maintaining the in-memory call graph,which records the
        @frompc,@selfpc,and the number of times each of these call arcs was
        transversed.
        
        assembly code :
                .file   "<stdin>"
                .text
                .globl  main
                .type   main, @function
        main:
        .LFB0:
                .cfi_startproc
                pushq   %rbp
                .cfi_def_cfa_offset 16
                .cfi_offset 6, -16
                movq    %rsp, %rbp
                .cfi_def_cfa_register 6
        1:      call    mcount                # call to mcount(),common routine.
                movl    $0, %eax
                popq    %rbp
                .cfi_def_cfa 7, 8
                ret
                .cfi_endproc
        .LFE0:
                .size   main, .-main
                .ident  "GCC: (GNU) 15.2.0"
                .section        .note.GNU-stack,"",@progbits

        main() stack :
                [  Red Zone ]
                [    ...    ]
                [    ...    ]
                [    ip     ]  # rip to next instruction where main() is called

        @frompc => ip
        @selfpc => rip of "call mcount" - sizeof("call mcount")

        if we can hacking mcount(),then we can customize the behavior of profiling.
        for userspace program,the compiled executable file is linked with libc,
        in which mcount() is defined.but for kernel,no libc is available,thus we
        can define mcount() specified to the kernel.
                void mcount(void);  /* prototype */
        usually,we need to export "mcount" symbol for modules.
                extern void mcount(void);
                EXPORT_SYMBOL(mcount);

        because mcount() will be called a lot of times,we need optimize it when
        ftrace is not enabled,to improve performance of OS in normal case.
                /* this type-definition is defined in <linux/ftrace.h> */
                typedef void (*ftrace_func_t)(unsigned long ip, unsigned long parent_ip,
                                              struct ftrace_ops *op,
                                              struct ftrace_regs *fregs);
                extern ftrace_func_t ftrace_trace_function;
                
                /* this function is defined in <arch/x86/kernel/ftrace_64.S>
                 * in assembly language,it just executes "CALL_DEPTH_ACCOUNT"
                 * and execute "RET" instruction.
                 * # CALL_DEPATH_ACCOUNT is an assembly macro defined in
                 *   <arch/x86/include/asm/nospec-branch.h>,to executes
                 *   X86_FEATURE_CALL_DEPTH.
                 * # this is default behavior that no ftrace is enabled.
                 */
                void ftrace_stub(unsigned long a1, unsigned long a2,
                                 struct ftrace_ops *op, struct ftrace_regs *fregs)
                {
                    return;
                }

                void mcount(void)
                {
                        /* save any bare state needed in order to do initial checking */
                        if (ftrace_trace_function != ftrace_stub)
                                goto do_trace;
                        /* restore any bare state */
                        return;
                do_trace:
                        /* save all state needed by the ABI */
                        /* construct @frompc and @selfpc */
                        /* @selfpc = return address - MCOUNT_INSN_SIZE; */
                        ftrace_trace_function(@selfpc, @frompc, @ftrace_ops, @ftrace_regs);
                        /* restore all state needed by the ABI */
                }   
                
