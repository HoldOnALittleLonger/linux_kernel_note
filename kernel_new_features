ftrace :
        ftrace relies the profile feature mcount(),which is a function included
        in the profiling library.when compile program with "-pg" gcc option,
        an assembly instruction "call mcount" is inserted to the head of the
        function.
        mcount() routine recording in an in-memory call graph table both its
        parent routine(child, function called mcount()),and its parent's parent
        (the routine called mcount()'s parent).
        this is typically done by examining the stack frame to find both the
        address of the child,and the return address in the original parent.
        because this is machine-dependent,thus mcount() will call to the
        function __mcount_internal()(a normal C function),which is architecture
        dependent,pass the function @frompc and @selfpc.
        @frompc is the program counter where this child function is called(next ins),
        and @selfpc the address of this child routine(with mcount() size adjustment,
        remove size of the mcount() call that is embedded in the function).
        __mcount_internal() maintaining the in-memory call graph,which records the
        @frompc,@selfpc,and the number of times each of these call arcs was
        transversed.
        
        assembly code :
                .file   "<stdin>"
                .text
                .globl  main
                .type   main, @function
        main:
        .LFB0:
                .cfi_startproc
                pushq   %rbp
                .cfi_def_cfa_offset 16
                .cfi_offset 6, -16
                movq    %rsp, %rbp
                .cfi_def_cfa_register 6
        1:      call    mcount                # call to mcount(),common routine.
                movl    $0, %eax
                popq    %rbp
                .cfi_def_cfa 7, 8
                ret
                .cfi_endproc
        .LFE0:
                .size   main, .-main
                .ident  "GCC: (GNU) 15.2.0"
                .section        .note.GNU-stack,"",@progbits

