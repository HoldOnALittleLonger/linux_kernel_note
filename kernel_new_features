        union bpf_attr :
          this union used to pass accompanying data to eBPF,it can has different
          variants depends on eBPF command.

          /**
           * bpf_attr - the accompanying data structure for bpf system call.
           *            there is not full definitions of this union,just copied
           *            from Man page.
           *            the detail is included in <linux/bpf.h>,and in which
           *            more members are existing.
           */
          union bpf_attr {
                  /* BPF_MAP_CREATE */
                  struct {
                          __u32 map_type;    /* map type */
                          __u32 key_size;    /* size of key */
                          __u32 value_size;  /* size of value */
                          __u32 max_entries  /* maximum entries in map */
                  };

                  /* BPF_MAP_*_ELEM,BPF_MAP_GET_NEXT_KEY */
                  struct {
                          __u32 map_fd;
                          /* pointers to buffer saved key */
                          __aligned_u64 key;
                          union {
                                  /* pointer to buffer saves value */
                                  __aligned_u64 value;
                                  /* pointer to buffer saves next key */
                                  __aligned_u64 next_key;
                          };
                          __u64 flags; /* BPF_ANY - create new or update existing
                                        * BPF_NOEXIST - create new if did not exist
                                        * BPF_EXIST - update existing
                                        * # for lookup,we can left this
                                        *   field be _zero_.
                                        */
                  };                        

                  /* BPF_PROG_LOAD */                    
                  struct {
                          __u32 prog_type;        /* program type */
                          __u32 insn_cnt;         /* number of insns */
                          __aligned_u64 insns;    /* const struct bpf_insn * */
                          __aligned_u64 license;  /* const char * */
                          __u32 log_level;        /* verbosity level of verifier */
                          __u32 log_size;         /* size of user buffer */
                          __aligned_u64 log_buf;  /* user supplied char * buffer */
                          __u32 kern_version;     /* checked when type is kprobe */
                  };
          } __attribute__((aligned(8)));

